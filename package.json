{
  "name": "hampshire-bins",
  "version": "0.1.0",
  "description": "Hampshire Bin Collection Data Platform - Production-grade API for bin collection schedules",
  "main": "dist/api/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/workers/acquisition-worker.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "start:worker": "node dist/workers/acquisition-worker.js",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:security": "vitest run --dir tests/security",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "openapi:validate": "npx @redocly/cli lint openapi.yaml",
    "security:audit": "npm audit && npx better-npm-audit audit",
    "prepare": "husky"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.35.0",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^5.8.4",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.48.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.26.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}

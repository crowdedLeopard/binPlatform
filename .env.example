# API Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# API Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SALT=$2b$10$EXAMPLE_SALT_DO_NOT_USE_IN_PRODUCTION
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET

# Database Configuration
DATABASE_URL=postgresql://binday:binday_dev_password@localhost:5432/binday
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://:redis_dev_password@localhost:6379
REDIS_PASSWORD=redis_dev_password
REDIS_TLS=false

# Azure Blob Storage (or use S3-compatible)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=evidence
# Alternative: Use workload identity in production
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_USE_MANAGED_IDENTITY=true

# AWS S3 (if using S3 instead of Azure)
# AWS_REGION=eu-west-2
# AWS_S3_BUCKET=bin-evidence
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Admin API Key (hashed)
# Generate hash with bcrypt cost 12
ADMIN_API_KEY_HASH=$2b$12$EXAMPLE_HASH_CHANGE_IN_PRODUCTION

# Feature Flags - Adapter Kill Switches
ADAPTER_KILL_SWITCH_BASINGSTOKE=false
ADAPTER_KILL_SWITCH_EAST_HAMPSHIRE=false
ADAPTER_KILL_SWITCH_EASTLEIGH=false
ADAPTER_KILL_SWITCH_FAREHAM=false
ADAPTER_KILL_SWITCH_GOSPORT=false
ADAPTER_KILL_SWITCH_HART=false
ADAPTER_KILL_SWITCH_HAVANT=false
ADAPTER_KILL_SWITCH_NEW_FOREST=false
ADAPTER_KILL_SWITCH_PORTSMOUTH=false
ADAPTER_KILL_SWITCH_RUSHMOOR=false
ADAPTER_KILL_SWITCH_SOUTHAMPTON=false
ADAPTER_KILL_SWITCH_TEST_VALLEY=false
ADAPTER_KILL_SWITCH_WINCHESTER=false

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SCREENSHOT_ON_FAILURE=true

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Observability
LOG_LEVEL=info
LOG_PRETTY=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hampshire-bin-platform
OTEL_TRACES_ENABLED=false
OTEL_METRICS_ENABLED=false

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Request Limits
REQUEST_BODY_SIZE_LIMIT=1048576
REQUEST_TIMEOUT_MS=30000
